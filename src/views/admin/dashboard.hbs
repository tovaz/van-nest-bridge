<div class="glass-panel w-full max-w-3xl rounded-xl p-8 shadow-2xl transition-all duration-300 mx-auto mt-10">
    <div class="flex justify-between items-start mb-6 border-b border-disable/30 pb-4">
        <div>
            <h1 class="text-3xl font-bold text-primary">Configuración del Sistema</h1>
            <p class="text-sm font-semibold text-highlight mt-1">Configuración persistente almacenada en SQLite</p>
        </div>
        <button id="logoutBtn"
            class="text-sm px-3 py-1 bg-disable hover:bg-danger text-light rounded-md transition-colors cursor-pointer">
            Cerrar sesión
        </button>
    </div>

    <form id="configForm" class="flex flex-col gap-8">

        <!-- === Sección General === -->
        <div>
            <h2 class="text-lg font-bold text-primary mb-4 border-b border-disable/20 pb-2">General</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                <div class="flex flex-col">
                    <label class="text-sm font-bold mb-0.5 text-text">Directorio de Logs</label>
                    <p class="text-xs text-accent mb-1">Ruta donde se guardarán los archivos de log. Puede ser relativa
                        (<code>./logs</code>) o absoluta (<code>C:\logs</code>).</p>
                    <input type="text" id="logDir" placeholder="C:\VAN_RUN\logsangular" value="{{config.logDir}}" required
                        class="px-4 py-2.5 bg-light border border-disable rounded-md focus:outline-none focus:ring-2 focus:ring-primary transition-all">
                </div>

                <div class="flex flex-col">
                    <label class="text-sm font-bold mb-0.5 text-text">Nivel de Log <span
                            class="font-normal text-highlight">(actual: {{config.logLevel}})</span></label>
                    <p class="text-xs text-accent mb-1">Filtra qué mensajes se guardan. <code>debug</code> guarda todo;
                        <code>error</code> guarda solo críticos. Cada nivel incluye los superiores.</p>
                    <select id="logLevel" required
                        class="px-4 py-2.5 bg-light border border-disable rounded-md focus:outline-none focus:ring-2 focus:ring-primary transition-all">
                        <option value="error">error — Solo errores críticos</option>
                        <option value="warn">warn — Advertencias y errores</option>
                        <option value="info">info — Información general</option>
                        <option value="http">http — Incluye peticiones HTTP</option>
                        <option value="verbose">verbose — Detalle ampliado</option>
                        <option value="debug">debug — Todo (máximo detalle)</option>
                    </select>
                </div>

                <div class="flex flex-col">
                    <label class="text-sm font-bold mb-0.5 text-text">Retención de Archivos</label>
                    <p class="text-xs text-accent mb-1">Tiempo o cantidad de archivos a conservar. Ej: <code>30d</code>
                        elimina archivos con más de 30 días; <code>10</code> conserva solo los últimos 10.</p>
                    <input type="text" id="logMaxFiles" placeholder="30d" value="{{config.logMaxFiles}}" required
                        class="px-4 py-2.5 bg-light border border-disable rounded-md focus:outline-none focus:ring-2 focus:ring-primary transition-all">
                </div>

                <div class="flex flex-col">
                    <label class="text-sm font-bold mb-0.5 text-text">Patrón del Nombre de Archivo</label>
                    <p class="text-xs text-accent mb-1">Nombre del archivo de log con el marcador <code>%DATE%</code>
                        donde se insertará la fecha automáticamente.</p>
                    <input type="text" id="logFilePattern" placeholder="van-front-%DATE%.log" value="{{config.logFilePattern}}"
                        required
                        class="px-4 py-2.5 bg-light border border-disable rounded-md focus:outline-none focus:ring-2 focus:ring-primary transition-all">
                </div>

            </div>
        </div>

        <!-- === Sección Rotación === -->
        <div>
            <h2 class="text-lg font-bold text-primary mb-4 border-b border-disable/20 pb-2">Rotación de Logs</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-2">

                <div class="flex flex-col">
                    <label class="text-sm font-bold mb-0.5 text-text">Patrón de Fecha</label>
                    <p class="text-xs text-accent mb-1">Formato de la fecha que reemplaza a <code>%DATE%</code>. Ej:
                        <code>YYYY-MM-DD</code> genera una rotación diaria.</p>
                    <input type="text" id="logDatePattern" placeholder="MM-DD-YYYY" value="{{config.logDatePattern}}"
                        required
                        class="px-4 py-2.5 bg-light border border-disable rounded-md focus:outline-none focus:ring-2 focus:ring-primary transition-all">
                </div>

                <div class="flex flex-col">
                    <label class="text-sm font-bold mb-0.5 text-text">Tamaño Máximo por Archivo</label>
                    <p class="text-xs text-accent mb-1">Peso máximo que puede alcanzar un archivo antes de rotar.
                        Formato: número + unidad. Ej: <code>20m</code>, <code>500k</code>, <code>1g</code>.</p>
                    <input type="text" id="logMaxSize" placeholder="10m" value="{{config.logMaxSize}}"
                        pattern="\d+[kKmMgG]" title="Ej: 20m, 500k, 1g" required
                        class="px-4 py-2.5 bg-light border border-disable rounded-md focus:outline-none focus:ring-2 focus:ring-primary transition-all">
                </div>

                <div class="flex flex-col">
                    <label class="text-sm font-bold mb-0.5 text-text">Subcarpeta de Archivo</label>
                    <p class="text-xs text-accent mb-1">Patrón de subcarpeta donde se moverán los archivos rotados. Usa
                        <code>YYYY-MM</code> para agrupar por mes. Déjalo vacío para no usar subcarpetas.</p>
                    <input type="text" id="logArchiveDirPattern" placeholder="YYYY-MM" title="Ej: YYYY-MM agrupa por mes"
                        value="{{config.logArchiveDirPattern}}"
                        class="px-4 py-2.5 bg-light border border-disable rounded-md focus:outline-none focus:ring-2 focus:ring-primary transition-all">
                </div>

                <div class="flex flex-col justify-center">
                    <label class="text-sm font-bold mb-0.5 text-text">Comprimir Archivos Rotados (GZIP)</label>
                    <p class="text-xs text-accent mb-2">Comprime los archivos rotados en formato <code>.gz</code> para
                        ahorrar espacio.</p>
                    <label class="toggle-switch">
                        <input type="checkbox" id="logZippedArchive"
                            {{#if config.logZippedArchive}}checked{{/if}}>
                        <span class="toggle-track">
                            <span class="toggle-thumb"></span>
                        </span>
                        <span id="zipToggleLabel" class="toggle-label {{#if config.logZippedArchive}}is-on{{/if}}">
                            {{#if config.logZippedArchive}}Activado{{else}}Desactivado{{/if}}
                        </span>
                    </label>
                </div>

            </div>
        </div>

        <p id="configFeedback" class="text-sm font-bold text-center min-h-[20px] mt-2"></p>

        <button type="submit" id="saveBtn"
            class="w-full bg-primary hover:bg-buttonPressed text-light py-3 rounded-md font-bold transition-all active:scale-[0.98] mt-2 shadow-md">
            Guardar y Aplicar Configuración
        </button>
    </form>
</div>

<!-- Frontend SPA Logic -->
<script>
    const authHeader = sessionStorage.getItem('van-auth-token');

    // Multi-Page App Separation: Redirect back to login if they bypassed the system
    if (!authHeader) {
        window.location.href = '/admin/login';
    }

    const serverConfig = {{{ configJson }}};
    const logLevelSelect = document.getElementById('logLevel');
    const configForm = document.getElementById('configForm');
    const configFeedback = document.getElementById('configFeedback');
    const logoutBtn = document.getElementById('logoutBtn');
    const zipToggleLabel = document.getElementById('zipToggleLabel');
    const logZippedArchiveCheckbox = document.getElementById('logZippedArchive');

    if (serverConfig && serverConfig.logLevel) {
        logLevelSelect.value = serverConfig.logLevel;
    }

    logZippedArchiveCheckbox.addEventListener('change', () => {
        const checked = logZippedArchiveCheckbox.checked;
        zipToggleLabel.textContent = checked ? 'Activado' : 'Desactivado';
        zipToggleLabel.classList.toggle('is-on', checked);
    });

    logoutBtn.addEventListener('click', () => {
        sessionStorage.removeItem('van-auth-token');
        window.location.href = '/admin/login';
    });

    configForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        configFeedback.innerText = '';
        const saveBtn = document.getElementById('saveBtn');
        saveBtn.disabled = true;
        saveBtn.innerText = 'Aplicando configuración...';

        const payload = {
            logDir: document.getElementById('logDir').value,
            logFilePattern: document.getElementById('logFilePattern').value,
            logDatePattern: document.getElementById('logDatePattern').value,
            logLevel: document.getElementById('logLevel').value,
            logMaxSize: document.getElementById('logMaxSize').value,
            logMaxFiles: document.getElementById('logMaxFiles').value,
            logZippedArchive: document.getElementById('logZippedArchive').checked,
            logArchiveDirPattern: document.getElementById('logArchiveDirPattern').value,
        };

        try {
            const res = await fetch('/admin/config', {
                method: 'POST',
                headers: {
                    'Authorization': authHeader,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            if (!res.ok) {
                if (res.status === 401) {
                    sessionStorage.removeItem('van-auth-token');
                    window.location.href = '/admin/login';
                    return;
                }
                const errData = await res.json();
                throw new Error(errData.message || 'Error al actualizar la configuración');
            }

            configFeedback.className = 'text-sm font-bold text-center min-h-[20px] mt-2 text-success';
            configFeedback.innerText = '✓ Configuración guardada y logger reiniciado correctamente.';
        } catch (err) {
            configFeedback.className = 'text-sm font-bold text-center min-h-[20px] mt-2 text-danger';
            configFeedback.innerText = Array.isArray(err.message) ? err.message.join(', ') : err.message;
        } finally {
            saveBtn.disabled = false;
            saveBtn.innerText = 'Guardar y Aplicar Configuración';
        }
    });

    // Final security check async against server
    fetch('/admin/config', { headers: { 'Authorization': authHeader } })
        .then(r => {
            if (!r.ok) {
                sessionStorage.removeItem('van-auth-token');
                window.location.href = '/admin/login';
            }
        });
</script>