{
  "name": "van-nest-logger",
  "version": "1.0.0",
  "description": "Local logger system built with NestJS, Winston and daily log rotation",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build:scss": "sass public/scss:public/css",
    "watch:scss": "sass --watch public/scss:public/css",
    "build:css": "npx tailwindcss -i ./public/css/tailwind-input.css -o ./public/css/tailwind.css",
    "watch:css": "npx tailwindcss -i ./public/css/tailwind-input.css -o ./public/css/tailwind.css --watch",
    "build": "npm run build:css && npm run build:scss && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run build:css && npm run build:scss && nest start",
    "start:dev": "npm run build:css && npm run build:scss && nest start --watch",
    "start:debug": "npm run build:css && npm run build:scss && nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "bin": "dist/main.js",
  "pkg": {
    "scripts": [],
    "assets": [
      "public/**/*",
      "views/**/*",
      ".env"
    ]
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "hbs": "^4.2.0",
    "joi": "^17.12.2",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sass": "^1.98.0",
    "sqlite3": "^6.0.1",
    "typeorm": "^0.3.28",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.28",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "postcss": "^8.5.8",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
